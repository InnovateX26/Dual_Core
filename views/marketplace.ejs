<%- include('partials/header') %>
<%- include('partials/navbar') %>
<%- include('partials/sidebar') %>
<% locals.activeMenu = 'marketplace' %>

<div class="bg-decoration">
  <div class="circle circle-1"></div>
  <div class="circle circle-2"></div>
</div>

<main class="main-content">
  <div class="page-header d-flex justify-between align-center">
    <div>
      <h1><i class="fas fa-store" style="color:var(--primary);"></i> Crop Marketplace</h1>
      <p>Browse and buy fresh crops directly from farmers.</p>
    </div>
    <button class="btn btn-primary" onclick="document.getElementById('addModal').classList.add('active')">
      <i class="fas fa-plus"></i> Add Listing
    </button>
  </div>

  <!-- Filters -->
  <div class="card mb-3">
    <div class="card-body">
      <form action="/marketplace" method="GET" style="display:flex;gap:12px;flex-wrap:wrap;align-items:flex-end;">
        <div class="form-group" style="margin:0;flex:1;min-width:150px;">
          <label class="form-label">Crop Name</label>
          <input type="text" name="crop" class="form-control" placeholder="Search crop..." value="<%= typeof filters !== 'undefined' && filters.crop ? filters.crop : '' %>">
        </div>
        <div class="form-group" style="margin:0;flex:1;min-width:150px;">
          <label class="form-label">Location</label>
          <input type="text" name="location" class="form-control" placeholder="Filter by location..." value="<%= typeof filters !== 'undefined' && filters.location ? filters.location : '' %>">
        </div>
        <div class="form-group" style="margin:0;min-width:100px;">
          <label class="form-label">Min Price</label>
          <input type="number" name="min_price" class="form-control" placeholder="₹0" value="<%= typeof filters !== 'undefined' && filters.min_price ? filters.min_price : '' %>">
        </div>
        <div class="form-group" style="margin:0;min-width:100px;">
          <label class="form-label">Max Price</label>
          <input type="number" name="max_price" class="form-control" placeholder="₹999" value="<%= typeof filters !== 'undefined' && filters.max_price ? filters.max_price : '' %>">
        </div>
        <button type="submit" class="btn btn-primary">🔍 Search</button>
        <a href="/marketplace" class="btn btn-secondary">Clear</a>
      </form>
    </div>
  </div>

  <!-- Listings Grid -->
  <% if (listings.length > 0) { %>
    <div class="grid-4">
      <% listings.forEach(listing => { %>
        <div class="listing-card">
          <div class="listing-image">
            <% if (listing.image_path) { %>
              <img src="<%= listing.image_path %>" alt="<%= listing.crop_name %>">
            <% } else { %>
              🌾
            <% } %>
          </div>
          <div class="listing-body">
            <div class="listing-title"><%= listing.crop_name %></div>
            <div class="listing-price">₹<%= listing.price %>/<%= listing.unit %></div>
            <div class="listing-meta">
              <span>📦 <%= listing.quantity %> <%= listing.unit %> available</span>
              <span>👤 <%= listing.farmer_name %></span>
              <span>📍 <%= listing.location || listing.farmer_location || 'India' %></span>
            </div>
            <a href="/marketplace/listing/<%= listing.id %>" class="btn btn-secondary btn-sm w-100 mt-2">View Details</a>
          </div>
        </div>
      <% }) %>
    </div>
  <% } else { %>
    <div class="card">
      <div class="empty-state">
        <div class="empty-icon">🛒</div>
        <h3>No listings found</h3>
        <p>Be the first to list your crops on the marketplace!</p>
        <button class="btn btn-primary" onclick="document.getElementById('addModal').classList.add('active')">➕ Add Listing</button>
      </div>
    </div>
  <% } %>
</main>

<!-- Add Listing Modal -->
<div class="modal-overlay" id="addModal">
  <div class="modal">
    <div class="modal-header">
      <h3>➕ Add New Listing</h3>
      <button class="modal-close" onclick="document.getElementById('addModal').classList.remove('active')">✕</button>
    </div>
    <form action="/marketplace/create" method="POST" enctype="multipart/form-data">
      <div class="modal-body">
        <div class="form-group">
          <label class="form-label">Crop Name</label>
          <select name="crop_name" class="form-control" required>
            <option value="">Select Crop</option>
            <option value="Rice">Rice</option>
            <option value="Wheat">Wheat</option>
            <option value="Tomato">Tomato</option>
            <option value="Potato">Potato</option>
            <option value="Maize">Maize</option>
            <option value="Cotton">Cotton</option>
            <option value="Sugarcane">Sugarcane</option>
            <option value="Onion">Onion</option>
            <option value="Soybean">Soybean</option>
          </select>
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
          <div class="form-group">
            <label class="form-label">Quantity</label>
            <input type="number" name="quantity" class="form-control" placeholder="e.g. 500" step="0.1" required>
          </div>
          <div class="form-group">
            <label class="form-label">Unit</label>
            <select name="unit" class="form-control">
              <option value="kg">Kilogram (kg)</option>
              <option value="quintal">Quintal</option>
              <option value="ton">Ton</option>
            </select>
          </div>
        </div>
        <div class="form-group">
          <label class="form-label">Price (₹ per unit)</label>
          <input type="number" name="price" class="form-control" placeholder="e.g. 25" step="0.01" required>
        </div>
        <div class="form-group">
          <label class="form-label">Location</label>
          <input type="text" name="location" class="form-control" placeholder="Village/City, State">
        </div>
        <div class="form-group">
          <label class="form-label">Description</label>
          <textarea name="description" class="form-control" rows="3" placeholder="Describe your crop quality, freshness, etc."></textarea>
        </div>
        <div class="form-group">
          <label class="form-label">Crop Image</label>
          <input type="file" name="cropImage" class="form-control" accept="image/*">
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" onclick="document.getElementById('addModal').classList.remove('active')">Cancel</button>
        <button type="submit" class="btn btn-primary">Create Listing</button>
      </div>
    </form>
  </div>
</div>

<%- include('partials/footer') %>
