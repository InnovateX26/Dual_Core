<%- include('../partials/header') %>
<div class="bg-decoration"><div class="circle circle-1"></div><div class="circle circle-2"></div></div>
<div class="auth-container">
  <div class="auth-card">
    <div style="text-align:center;margin-bottom:24px;">
      <div class="brand-icon" style="width:48px;height:48px;font-size:22px;margin:0 auto 12px;"><i class="fas fa-leaf"></i></div>
      <h1>Welcome Back</h1>
      <p class="subtitle">Sign in to AgriConnect</p>
    </div>

    <% if (typeof error_msg !== 'undefined' && error_msg.length > 0) { %>
      <div class="alert alert-error" style="margin-bottom:16px;"><i class="fas fa-exclamation-circle"></i> <%= error_msg %></div>
    <% } %>

    <form action="/auth/login" method="POST">
      <div class="form-group">
        <label class="form-label"><i class="fas fa-envelope"></i> Email</label>
        <input type="email" name="email" class="form-control" placeholder="farmer@example.com" required>
      </div>
      <div class="form-group">
        <label class="form-label"><i class="fas fa-lock"></i> Password</label>
        <input type="password" name="password" class="form-control" placeholder="Enter your password" required>
      </div>
      <button type="submit" class="btn btn-primary btn-lg w-100"><i class="fas fa-sign-in-alt"></i> Sign In</button>
    </form>
    <div class="auth-footer">
      Don't have an account? <a href="/auth/register">Create one free</a>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>
